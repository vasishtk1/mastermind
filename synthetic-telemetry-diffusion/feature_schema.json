{
  "version": "1.0",
  "window_seconds": 30,
  "batch_ms": 500,
  "description": "One row = aggregated 500ms telemetry batches over a fixed lookback. Column order is frozen — diffusion and downstream models must use this exact order.",
  "feature_names": [
    "n_batches_norm",
    "audio_rms_db_mean_avg",
    "audio_rms_db_mean_std",
    "audio_rms_db_mean_max",
    "audio_f0_mean_avg",
    "audio_f0_mean_var",
    "audio_spectral_flux_mean_avg",
    "audio_spectral_flux_mean_std",
    "audio_spectral_centroid_mean_avg",
    "audio_zcr_mean_avg",
    "audio_zcr_mean_std",
    "audio_ambient_db_mean_avg",
    "audio_silence_ratio",
    "face_blink_combined_mean_avg",
    "face_blink_combined_mean_var",
    "face_head_pitch_mean_avg",
    "face_head_pitch_mean_var",
    "face_head_yaw_mean_avg",
    "face_head_yaw_mean_var",
    "face_head_roll_mean_avg",
    "face_head_roll_mean_var",
    "face_frame_count_mean",
    "motion_accel_magnitude_mean_avg",
    "motion_accel_magnitude_mean_std",
    "motion_accel_magnitude_max_peak",
    "motion_tremor_index_mean",
    "motion_spike_count",
    "motion_orientation_beta_mean_avg",
    "motion_orientation_gamma_mean_avg",
    "pointer_tap_rate",
    "pointer_mean_pressure_avg",
    "pointer_mean_velocity_avg",
    "pointer_interaction_dropoff",
    "audio_rms_db_mean_slope",
    "audio_spectral_flux_mean_slope",
    "motion_accel_magnitude_mean_slope"
