# Convex — Web (Vite) + iOS must use the SAME deployment URL for data to sync.

# --- Production (Convex Cloud) ---
# Deployment dashboard: https://acoustic-minnow-665.convex.cloud/
# HTTP actions / site (if you use Convex HTTP routes): https://acoustic-minnow-665.convex.site
VITE_CONVEX_URL=https://acoustic-minnow-665.convex.cloud

# Optional: only if you use Convex-hosted HTTP endpoints in the browser
# VITE_CONVEX_SITE_URL=https://acoustic-minnow-665.convex.site

# --- Local dev (overrides when running `npx convex dev` — writes .env.local) ---
# VITE_CONVEX_URL=http://127.0.0.1:3210
