# Copy this file to .env and fill in your keys.
# The backend reads this file automatically via python-dotenv.
GEMINI_API_KEY=your-gemini-api-key-here

# Convex deployment URL for real-time dashboard sync.
# Find this in your Convex dashboard or .env.local (VITE_CONVEX_URL).
# Example: https://acoustic-minnow-665.convex.cloud
CONVEX_URL=https://acoustic-minnow-665.convex.cloud
